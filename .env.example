# Anthropic
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# Paths
LIFE_OS_ROOT=/home/{user}/life-os

# Web hub — shared secret for the dashboard. Gates both the browser login
# (session cookie) and the /api/* Bearer header. Unset = auth disabled
# (local dev / first-boot grace).
LIFE_OS_DASHBOARD_TOKEN=
